---
import type { SiteLocale } from '../utils/paths';

interface Props {
  locale?: SiteLocale;
}

const { locale = 'en' } = Astro.props;
const footerCopy = locale === 'zh' ? '用教學內容整理學習過程。' : 'Use teaching content to organize the learning journey.';
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p>{footerCopy}</p>
  </div>
</footer>
