---
import { courses } from '../data/courses';
import type { Course } from '../data/courses';
import { detectLocaleFromPathname, localizePath, withBase } from '../utils/paths';
import type { SiteLocale } from '../utils/paths';

interface Props {
  currentCourse?: Course | null;
  showPrimaryNav?: boolean;
  locale?: SiteLocale;
}

const { currentCourse = null, showPrimaryNav = true, locale = 'en' } = Astro.props;
const isChinese = locale === 'zh';
const pathname = Astro.url.pathname;
const currentLocale = detectLocaleFromPathname(pathname);
const englishPath = localizePath(pathname, 'en');
const chinesePath = localizePath(pathname, 'zh');
const dropdownLabel = currentCourse ? currentCourse.title : isChinese ? '課程選單' : 'Course menu';
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={withBase('/', locale)}>
      <span class="brand-title brand-title--full">Tommy's Learning Notes</span>
      <span class="brand-title brand-title--compact">Tommy Notes</span>
    </a>

    {showPrimaryNav && (
      <nav class="header-nav" aria-label="Primary">
        <a href={withBase('/courses', locale)}>{isChinese ? '文章分類' : 'Courses'}</a>
        <a href={withBase('/#recent-lessons', locale)}>{isChinese ? '最新整理' : 'Latest updates'}</a>
      </nav>
    )}

    <div class="header-actions">
      <div class="language-switch" aria-label={isChinese ? '語言切換' : 'Language switch'}>
        <a href={englishPath} class:list={['language-link', { 'is-active': currentLocale === 'en' }]}>EN</a>
        <a href={chinesePath} class:list={['language-link', { 'is-active': currentLocale === 'zh' }]}>中文</a>
      </div>

      <details class="course-dropdown">
        <summary aria-label={dropdownLabel}>
          <span class="course-dropdown-label">{dropdownLabel}</span>
          <span class="course-dropdown-icon" aria-hidden="true">☰</span>
        </summary>

        <div class="course-menu">
          <p class="menu-label">{isChinese ? '課程選單' : 'Course menu'}</p>

          <ul class="course-menu-list">
            {courses.map((course) => (
              <li>
                <a
                  href={withBase(`/courses/${course.slug}`, locale)}
                  class:list={['course-menu-link', { 'is-active': currentCourse?.slug === course.slug }]}
                  aria-current={currentCourse?.slug === course.slug ? 'page' : undefined}
                >
                  <span class="course-menu-dot" style={`--course-accent: ${course.accent}`}></span>
                  <span class="course-menu-copy">
                    <span class="course-menu-title">{course.title}</span>
                    <span class="course-menu-subtitle">{course.category}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>

          <a href={withBase('/courses', locale)} class="course-menu-all">{isChinese ? '瀏覽所有課程筆記' : 'Browse all teaching notes'}</a>
        </div>
      </details>
    </div>
  </div>
</header>
