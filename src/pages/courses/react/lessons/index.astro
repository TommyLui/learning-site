---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { courses } from '../../../../data/courses';
import { getReactLessons } from '../../../../data/reactLessons';
import type { CourseLessonArticle } from '../../../../data/reactLessons';
import { withBase } from '../../../../utils/paths';

const course = courses.find((item) => item.slug === 'react');

if (!course) {
  throw new Error('React course not found');
}

const lessons: CourseLessonArticle[] = getReactLessons();
const firstLesson = lessons[0];
const latestLesson = lessons[lessons.length - 1];
const totalModules = course.modules.length;
const currentLessonCount = lessons.length;
const lessonsByModule = new Map<string, CourseLessonArticle[]>();

for (const lesson of lessons) {
  const existingLessons = lessonsByModule.get(lesson.moduleTitle) ?? [];
  existingLessons.push(lesson);
  lessonsByModule.set(lesson.moduleTitle, existingLessons);
}

const noteModules = course.modules.map((module) => ({
  title: module.title,
  description: module.description,
  lessons: lessonsByModule.get(module.title) ?? [],
}));

const roadmapHighlights = [
  'Use the module map first to see how React moves from component thinking into hooks, forms, and routing.',
  'This landing page and each lesson article now read from the same lesson data, instead of separate placeholder content.',
  'If you want to follow the core path in order, start from Lesson 1 and continue straight through the track.',
];
const learningPromises = [
  'Build a clear frontend mental model across components, props, state, and effects.',
  'Turn forms, routing, and project structure into one course flow you can revisit repeatedly.',
  'Open every lesson as a full article page instead of landing on an empty placeholder.',
];
---

<BaseLayout
  title={`React lessons · ${course.title}`}
  description="Browse the formal React lesson library and article pages."
  currentCourse={course}
>
  <section class="page-intro page-intro--course page-intro--editorial" style={`--course-accent: ${course.accent}`}>
    <div class="page-intro-backdrop"></div>
    <div class="container page-intro-inner">
      <a href={withBase('/courses')} class="back-link">← Back to all tracks</a>
      <div class="course-hero-grid course-hero-grid--editorial">
        <div>
          <p class="eyebrow">Course home</p>
          <h1 class="page-title">React lessons</h1>
          <p class="lead narrow">
            This track turns the React learning path into a readable course home, from foundations and hooks to app structure, with every stop connected to a full lesson article.
          </p>

          <div class="hero-actions course-home-actions">
            {firstLesson ? (
              <a class="hero-action hero-action--primary" href={withBase(`/courses/react/lessons/${firstLesson.slug}`)}>
                Start from Lesson 1
              </a>
            ) : null}
            {latestLesson ? (
              <a class="hero-action" href={withBase(`/courses/react/lessons/${latestLesson.slug}`)}>
                Jump to the final lesson
              </a>
            ) : null}
          </div>
        </div>

        <aside class="course-summary-card course-summary-card--editorial course-summary-card--dense">
          <h2>Notes overview</h2>
          <dl>
            <div>
              <dt>Current lessons</dt>
              <dd>{currentLessonCount}</dd>
            </div>
            <div>
              <dt>Planned lessons</dt>
              <dd>{course.totalLessons}</dd>
            </div>
            <div>
              <dt>Total modules</dt>
              <dd>{totalModules}</dd>
            </div>
            <div>
              <dt>Course focus</dt>
              <dd>{course.focus.join(', ')}</dd>
            </div>
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <section class="floating-panel-wrap floating-panel-wrap--page">
    <div class="container">
      <div class="main-panel">
        <section class="panel-section panel-section--first">
          <div class="section-heading section-heading--editorial">
            <h2>Start here</h2>
            <p>This page now shares the same lesson data as the article pages, so the reading order and content source stay aligned.</p>
          </div>

          <div class="course-home-grid">
            <article class="content-panel content-panel--editorial note-panel course-home-feature">
              <p class="eyebrow">Reading flow</p>
              <h3>Read the modules first, then move into the full lesson articles and follow the React path end to end</h3>
              <p>
                If you want to go from React beginner basics to structuring a medium-sized app, use this page to understand the flow first and then move lesson by lesson through the full articles.
              </p>
              <ul class="simple-list simple-list--compact">
                {roadmapHighlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            </article>

            <aside class="content-panel content-panel--editorial note-panel course-home-aside">
              <p class="eyebrow">What you will get</p>
              <h3>This React track connects the core frontend skills into one path you can revisit and review</h3>
              <ul class="simple-list simple-list--compact">
                {learningPromises.map((promise) => (
                  <li>{promise}</li>
                ))}
              </ul>
            </aside>
          </div>
        </section>

        <section class="panel-section">
          <div class="section-heading section-heading--editorial">
            <h2>Recommended path</h2>
            <p>If you do not want to decide the order yourself, start with this suggested sequence.</p>
          </div>

          <div class="course-home-steps">
            <article class="course-step-card">
              <span class="course-step-number">01</span>
              <h3>Start with component thinking</h3>
              <p>Get comfortable with JSX, components, and props first so state and hooks feel much steadier later.</p>
            </article>
            <article class="course-step-card">
              <span class="course-step-number">02</span>
              <h3>Then move into interaction logic</h3>
              <p>Clarify state, effects, and forms so React turns from a static screen into a truly interactive UI.</p>
            </article>
            <article class="course-step-card">
              <span class="course-step-number">03</span>
              <h3>Finish by shaping the app structure</h3>
              <p>Then move into routing, page structure, and project organization so the overall frontend architecture becomes complete.</p>
            </article>
          </div>
        </section>

        <section class="panel-section">
          <div class="section-heading section-heading--editorial">
            <h2>Module map</h2>
            <p>Use the module groups to understand the React path first, then dive into each lesson.</p>
          </div>

          <div class="module-list">
            {noteModules.map((module) => (
              <article class="module-card module-card--editorial module-card--course-home">
                <div class="module-head module-head--course-home">
                  <div>
                    <p class="eyebrow">Module</p>
                    <h3>{module.title}</h3>
                  </div>
                  <p>{module.description}</p>
                </div>

                <div class="notes-list notes-list--module">
                  {module.lessons.map((lesson) => (
                    <a class="note-card note-card--course-home" href={withBase(`/courses/react/lessons/${lesson.slug}`)}>
                      <div class="note-card-meta">
                        <span class="course-pill">Lesson {lesson.lesson}</span>
                        <span class="note-card-arrow" aria-hidden="true">↗</span>
                      </div>
                      <h3>{lesson.title}</h3>
                      <p>{lesson.summary}</p>
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="panel-section">
          <div class="section-heading section-heading--editorial">
            <h2>All lessons</h2>
            <p>Every lesson listed here already has a full article page behind it.</p>
          </div>

          <div class="notes-list notes-list--compact-cards">
            {lessons.map((lesson) => (
              <a class="note-card note-card--compact" href={withBase(`/courses/react/lessons/${lesson.slug}`)}>
                <div class="note-card-meta">
                  <span class="course-pill">Lesson {lesson.lesson}</span>
                  <span class="note-card-arrow" aria-hidden="true">↗</span>
                </div>
                <h3>{lesson.title}</h3>
                <p>{lesson.summary}</p>
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
