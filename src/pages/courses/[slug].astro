---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { courses } from '../../data/courses';
import type { Course } from '../../data/courses';
import { withBase } from '../../utils/paths';

export function getStaticPaths() {
  return courses.filter((course) => !['spring-boot', 'react', 'mysql'].includes(course.slug)).map((course) => ({
    params: { slug: course.slug },
    props: { course },
  }));
}

interface Props {
  course: Course;
}

const { course } = Astro.props;
const hasDedicatedNotes = true;
const noteLibraryPath = `/courses/${course.slug}/lessons`;
const noteLibraryHref = withBase(noteLibraryPath);

function getLessonHref(lessonNumber: string) {
  if (!hasDedicatedNotes) {
    return null;
  }

  const match = lessonNumber.match(/(\d+)/);
  return match && noteLibraryPath ? withBase(`${noteLibraryPath}/lesson-${match[1]}`) : noteLibraryHref;
}
---

<BaseLayout
  title={`${course.title} · Tommy's Notes`}
  description={course.subtitle}
  currentCourse={course}
>
  <section class="page-intro page-intro--course page-intro--editorial" style={`--course-accent: ${course.accent}`}>
    <div class="page-intro-backdrop"></div>
    <div class="container page-intro-inner">
      <a href={withBase('/courses')} class="back-link">← Back to all tracks</a>

      <div class="course-hero-grid course-hero-grid--editorial">
        <div>
          <p class="eyebrow">{course.category}</p>
          <h1 class="page-title">{course.title}</h1>
          <p class="lead narrow">{course.subtitle}</p>
          <p class="course-overview">{course.overview}</p>
        </div>

        <aside class="course-summary-card course-summary-card--editorial">
          <h2>Track summary</h2>
          <dl>
            <div>
              <dt>Level</dt>
              <dd>{course.level}</dd>
            </div>
            <div>
              <dt>Total lessons</dt>
              <dd>{course.totalLessons}</dd>
            </div>
            <div>
              <dt>Focus</dt>
              <dd>{course.focus.join(', ')}</dd>
            </div>
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <section class="floating-panel-wrap floating-panel-wrap--page">
    <div class="container">
      <div class="main-panel">
        <section class="panel-section panel-section--first">
          <div class="course-layout">
            <div class="course-main-column">
              <div class="content-panel content-panel--editorial">
                <div class="section-heading section-heading--editorial">
                  <h2>What this track covers</h2>
                  <p>Start by defining the learning goals so each lesson stays tied to a clear outcome.</p>
                </div>

                <ul class="simple-list">
                  {course.outcomes.map((outcome) => (
                    <li>{outcome}</li>
                  ))}
                </ul>
              </div>

              <div class="content-panel content-panel--editorial">
                <div class="section-heading section-heading--editorial">
                  <h2>Lesson map</h2>
                  <p>Each module represents a structured stage in the learning sequence.</p>
                </div>

                {hasDedicatedNotes && noteLibraryHref && (
                  <div class="note-library-callout">
                    <div>
                      <p class="eyebrow">Notes library</p>
                      <h3>This track already has a dedicated lesson library</h3>
                      <p>
                        You can start with the course map to understand the structure, then move directly into each lesson page to read the formal article draft.
                      </p>
                    </div>
                    <a class="course-link course-link--inline" href={noteLibraryHref}>
                      Browse all {course.title} lessons <span aria-hidden="true">→</span>
                    </a>
                  </div>
                )}

                <div class="module-list">
                  {course.modules.map((module) => (
                    <article class="module-card module-card--editorial">
                      <div class="module-head">
                        <h3>{module.title}</h3>
                        <p>{module.description}</p>
                      </div>

                      <div class="module-lessons">
                        {module.lessons.map((lesson) => {
                          const lessonHref = getLessonHref(lesson.number);

                          return (
                            <div class="module-lesson-row">
                              <div>
                                <p class="module-lesson-number">{lesson.number}</p>
                                {lessonHref ? (
                                  <h4>
                                    <a class="module-lesson-link" href={lessonHref}>{lesson.title}</a>
                                  </h4>
                                ) : (
                                  <h4>{lesson.title}</h4>
                                )}
                              </div>
                              <p>{lesson.summary}</p>
                            </div>
                          );
                        })}
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            </div>

            <aside class="course-side-column">
              <div class="content-panel content-panel--editorial sticky-panel">
                <div class="section-heading section-heading--editorial">
                  <h2>Before you begin</h2>
                  <p>List the prerequisites clearly first so the rest of the track feels smoother.</p>
                </div>

                <ul class="simple-list simple-list--compact">
                  {course.prerequisites.map((prerequisite) => (
                    <li>{prerequisite}</li>
                  ))}
                </ul>
              </div>
            </aside>
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
