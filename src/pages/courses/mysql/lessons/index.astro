---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { courses } from '../../../../data/courses';
import { getMySQLLessons } from '../../../../data/mysqlLessons';
import type { CourseLessonArticle } from '../../../../data/mysqlLessons';
import { withBase } from '../../../../utils/paths';

const course = courses.find((item) => item.slug === 'mysql');

if (!course) {
  throw new Error('MySQL course not found');
}

const lessons: CourseLessonArticle[] = getMySQLLessons();
const firstLesson = lessons[0];
const latestLesson = lessons[lessons.length - 1];
const totalModules = course.modules.length;
const currentLessonCount = lessons.length;
const lessonsByModule = new Map<string, CourseLessonArticle[]>();

for (const lesson of lessons) {
  const existingLessons = lessonsByModule.get(lesson.moduleTitle) ?? [];
  existingLessons.push(lesson);
  lessonsByModule.set(lesson.moduleTitle, existingLessons);
}

const noteModules = course.modules.map((module) => ({
  title: module.title,
  description: module.description,
  lessons: lessonsByModule.get(module.title) ?? [],
}));

const roadmapHighlights = [
  'Use the module map first to see how MySQL moves from query basics into schema design and performance.',
  'Use this page as your study map first, then open each lesson article when you want to go deeper.',
  'If you want to build the database path from the beginning, start at Lesson 1 and continue to the end.',
];
const learningPromises = [
  'Connect SELECT, INSERT, UPDATE, DELETE, joins, keys, and schema design into one clear database path.',
  'Understand the structural thinking behind relational databases instead of memorizing isolated SQL fragments.',
  'Open every lesson directly as a full article for deeper reading and review.',
];
---

<BaseLayout
  title={`MySQL lessons · ${course.title}`}
  description="Browse the formal MySQL lesson library and article pages."
  currentCourse={course}
>
  <section class="page-intro page-intro--course page-intro--editorial" style={`--course-accent: ${course.accent}`}>
    <div class="page-intro-backdrop"></div>
    <div class="container page-intro-inner">
      <a href={withBase('/courses')} class="back-link">← Back to all tracks</a>
      <div class="course-hero-grid course-hero-grid--editorial">
        <div>
          <p class="eyebrow">Course home</p>
          <h1 class="page-title">MySQL lessons</h1>
          <p class="lead narrow">
            This track turns the MySQL learning path into a readable course home, from query basics and relationships to schema design and performance, with every step connected to a full lesson article.
          </p>

          <div class="hero-actions course-home-actions">
            {firstLesson ? (
              <a class="hero-action hero-action--primary" href={withBase(`/courses/mysql/lessons/${firstLesson.slug}`)}>
                Start from Lesson 1
              </a>
            ) : null}
            {latestLesson ? (
              <a class="hero-action" href={withBase(`/courses/mysql/lessons/${latestLesson.slug}`)}>
                Jump to the final lesson
              </a>
            ) : null}
          </div>
        </div>

        <aside class="course-summary-card course-summary-card--editorial course-summary-card--dense">
          <h2>Notes overview</h2>
          <dl>
            <div>
              <dt>Current lessons</dt>
              <dd>{currentLessonCount}</dd>
            </div>
            <div>
              <dt>Planned lessons</dt>
              <dd>{course.totalLessons}</dd>
            </div>
            <div>
              <dt>Total modules</dt>
              <dd>{totalModules}</dd>
            </div>
            <div>
              <dt>Course focus</dt>
              <dd>{course.focus.join(', ')}</dd>
            </div>
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <section class="floating-panel-wrap floating-panel-wrap--page">
    <div class="container">
      <div class="main-panel">
        <section class="panel-section panel-section--first">
          <div class="section-heading section-heading--editorial">
            <h2>Start here</h2>
            <p>Use this page to understand the lesson sequence and big-picture flow before diving into each article.</p>
          </div>

          <div class="course-home-grid">
            <article class="content-panel content-panel--editorial note-panel course-home-feature">
              <p class="eyebrow">Reading flow</p>
              <h3>Start with query basics, then move into joins, and finish with schema and performance thinking</h3>
              <p>
                If you want to turn database knowledge into a stable learning path you can revisit, use this page to understand the structure first and then move through the lesson articles one by one.
              </p>
              <ul class="simple-list simple-list--compact">
                {roadmapHighlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            </article>

            <aside class="content-panel content-panel--editorial note-panel course-home-aside">
              <p class="eyebrow">What you will get</p>
              <h3>This MySQL track connects querying, relationships, and data design into a course you can truly revisit</h3>
              <ul class="simple-list simple-list--compact">
                {learningPromises.map((promise) => (
                  <li>{promise}</li>
                ))}
              </ul>
            </aside>
          </div>
        </section>

        <section class="panel-section">
          <div class="section-heading section-heading--editorial">
            <h2>Recommended path</h2>
            <p>If you do not want to choose the order yourself, follow this recommended sequence first.</p>
          </div>

          <div class="course-home-steps">
            <article class="course-step-card">
              <span class="course-step-number">01</span>
              <h3>Build strong query basics first</h3>
              <p>Read through SELECT, WHERE, ORDER BY, and data writes first so joins feel steadier later.</p>
            </article>
            <article class="course-step-card">
              <span class="course-step-number">02</span>
              <h3>Then understand relationships</h3>
              <p>Clarify joins, keys, and one-to-many thinking so you can really see how app data lands in tables.</p>
            </article>
            <article class="course-step-card">
              <span class="course-step-number">03</span>
              <h3>Finish with schema and performance</h3>
              <p>Then move into normalization, indexes, and practical design so your database thinking becomes more mature.</p>
            </article>
          </div>
        </section>

        <section class="panel-section">
          <div class="section-heading section-heading--editorial">
            <h2>Module map</h2>
            <p>Use the module groups to understand the MySQL path first, then open each lesson in detail.</p>
          </div>

          <div class="module-list">
            {noteModules.map((module) => (
              <article class="module-card module-card--editorial module-card--course-home">
                <div class="module-head module-head--course-home">
                  <div>
                    <p class="eyebrow">Module</p>
                    <h3>{module.title}</h3>
                  </div>
                  <p>{module.description}</p>
                </div>

                <div class="notes-list notes-list--module">
                  {module.lessons.map((lesson) => (
                    <a class="note-card note-card--course-home" href={withBase(`/courses/mysql/lessons/${lesson.slug}`)}>
                      <div class="note-card-meta">
                        <span class="course-pill">Lesson {lesson.lesson}</span>
                        <span class="note-card-arrow" aria-hidden="true">↗</span>
                      </div>
                      <h3>{lesson.title}</h3>
                      <p>{lesson.summary}</p>
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="panel-section">
          <div class="section-heading section-heading--editorial">
            <h2>All lessons</h2>
            <p>Every lesson listed here already has a full article page behind it.</p>
          </div>

          <div class="notes-list notes-list--compact-cards">
            {lessons.map((lesson) => (
              <a class="note-card note-card--compact" href={withBase(`/courses/mysql/lessons/${lesson.slug}`)}>
                <div class="note-card-meta">
                  <span class="course-pill">Lesson {lesson.lesson}</span>
                  <span class="note-card-arrow" aria-hidden="true">↗</span>
                </div>
                <h3>{lesson.title}</h3>
                <p>{lesson.summary}</p>
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
