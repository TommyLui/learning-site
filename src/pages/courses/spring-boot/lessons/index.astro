---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { courses } from '../../../../data/courses';
import { getSpringBootNotes } from '../../../../data/springbootNotes';
import type { SpringBootNote } from '../../../../data/springbootNotes';
import { withBase } from '../../../../utils/paths';

const course = courses.find((item) => item.slug === 'spring-boot');

if (!course) {
  throw new Error('Spring Boot course not found');
}

const notes: SpringBootNote[] = await getSpringBootNotes();
const notesBySlug = new Map(notes.map((note) => [note.slug, note]));
const noteModules = course.modules.map((module) => ({
  title: module.title,
  description: module.description,
  lessons: module.lessons
    .map((lesson) => {
      const lessonNumber = lesson.number.match(/(\d+)/)?.[1];
      return lessonNumber ? notesBySlug.get(`lesson-${lessonNumber}`) ?? null : null;
    })
    .filter((note): note is SpringBootNote => note !== null),
}));

const firstLesson = notes[0];
const latestLesson = notes[notes.length - 1];
const totalModules = noteModules.length;
const averageLessonsPerModule = Math.round(notes.length / totalModules);
const roadmapHighlights = [
  'Use the module map first to see how the course moves from core concepts all the way to deployment.',
  'Every lesson keeps its summary, full notes, practice, and official references so you can move from reading into real Spring Boot 3.x implementation.',
  'If you want to follow the track in order, start from Lesson 1 and continue straight through the continuity flow.',
];
const learningPromises = [
  'Understand how a Spring Boot 3.x project is assembled from Java 17+ startup and controllers through services and deployment.',
  'Connect REST APIs, Jakarta validation, Spring Data JPA/MySQL, and testing into one practical development path.',
  'See where Spring Security 6, Actuator, Docker, and deployment thinking should enter the learning flow.',
];
---

<BaseLayout
  title={`Spring Boot lessons · ${course.title}`}
  description="Browse the full Spring Boot 3.x lesson notes and article drafts."
  currentCourse={course}
>
  <section class="page-intro page-intro--course page-intro--editorial" style={`--course-accent: ${course.accent}`}>
    <div class="page-intro-backdrop"></div>
    <div class="container page-intro-inner">
      <a href={withBase('/courses')} class="back-link">← Back to all tracks</a>
      <div class="course-hero-grid course-hero-grid--editorial">
        <div>
          <p class="eyebrow">Course home</p>
          <h1 class="page-title">Spring Boot 3.x lesson library</h1>
          <p class="lead narrow">
            From Java 17+ setup, REST APIs, and JPA/MySQL to Spring Security 6, testing, and deployment, this page turns the Spring Boot 3.x path into a lesson library you can read through from start to finish.
          </p>

          <div class="hero-actions course-home-actions">
            {firstLesson ? (
              <a class="hero-action hero-action--primary" href={withBase(`/courses/spring-boot/lessons/${firstLesson.slug}`)}>
                Start from Lesson 1
              </a>
            ) : null}
            {latestLesson ? (
              <a class="hero-action" href={withBase(`/courses/spring-boot/lessons/${latestLesson.slug}`)}>
                Jump to the latest lesson
              </a>
            ) : null}
          </div>
        </div>

        <aside class="course-summary-card course-summary-card--editorial course-summary-card--dense">
          <h2>Notes overview</h2>
          <dl>
            <div>
              <dt>Total lessons</dt>
              <dd>{notes.length}</dd>
            </div>
            <div>
              <dt>Total modules</dt>
              <dd>{totalModules}</dd>
            </div>
            <div>
              <dt>Average pace</dt>
              <dd>{averageLessonsPerModule} lessons / module</dd>
            </div>
            <div>
              <dt>Course focus</dt>
              <dd>{course.focus.join(', ')}</dd>
            </div>
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <section class="floating-panel-wrap floating-panel-wrap--page">
    <div class="container">
      <div class="main-panel">
        <section class="panel-section panel-section--first">
          <div class="section-heading section-heading--editorial">
            <h2>Start here</h2>
            <p>This is more than a lesson list. It is the course landing page that shows how to enter, read, and finish the whole track.</p>
          </div>

          <div class="course-home-grid">
            <article class="content-panel content-panel--editorial note-panel course-home-feature">
              <p class="eyebrow">Reading flow</p>
              <h3>Read the whole map first, then move into each lesson, and keep going with lesson continuity</h3>
              <p>
                If this is your first time learning Spring Boot, use this page as the course entry point: confirm the full path with the module map, then enter the lesson articles and continue with the continuity links at the bottom of each page.
              </p>
              <ul class="simple-list simple-list--compact">
                {roadmapHighlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            </article>

            <aside class="content-panel content-panel--editorial note-panel course-home-aside">
              <p class="eyebrow">What you will get</p>
              <h3>By the end of this path, you will have a much clearer picture of how a Spring Boot project is built step by step</h3>
              <ul class="simple-list simple-list--compact">
                {learningPromises.map((promise) => (
                  <li>{promise}</li>
                ))}
              </ul>
            </aside>
          </div>
        </section>

        <section class="panel-section">
          <div class="section-heading section-heading--editorial">
            <h2>Module map</h2>
            <p>Use the module groups to understand the stages of the course before opening individual lessons.</p>
          </div>

          <div class="module-list">
            {noteModules.map((module) => (
              <article class="module-card module-card--editorial module-card--course-home">
                <div class="module-head module-head--course-home">
                  <div>
                    <p class="eyebrow">Module</p>
                    <h3>{module.title}</h3>
                  </div>
                  <p>{module.description}</p>
                </div>

                <div class="notes-list notes-list--module">
                  {module.lessons.map((note) => (
                    <a class="note-card note-card--course-home" href={withBase(`/courses/spring-boot/lessons/${note.slug}`)}>
                      <div class="note-card-meta">
                        <span class="course-pill">Lesson {note.lesson}</span>
                        <span class="note-card-arrow" aria-hidden="true">↗</span>
                      </div>
                      <h3>{note.title.replace(/^Lesson \d+:\s*/, '')}</h3>
                      <p>{note.summary}</p>
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="panel-section">
          <div class="section-heading section-heading--editorial">
            <h2>All lessons</h2>
            <p>If you want to jump to a specific lesson quickly, use the full list here.</p>
          </div>

          <div class="notes-list notes-list--compact-cards">
            {notes.map((note) => (
              <a class="note-card note-card--compact" href={withBase(`/courses/spring-boot/lessons/${note.slug}`)}>
                <div class="note-card-meta">
                  <span class="course-pill">Lesson {note.lesson}</span>
                  <span class="note-card-arrow" aria-hidden="true">↗</span>
                </div>
                <h3>{note.title.replace(/^Lesson \d+:\s*/, '')}</h3>
                <p>{note.summary}</p>
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
