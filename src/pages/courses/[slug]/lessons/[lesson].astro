---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import type { Course } from '../../../../data/courses';
import {
  getDataBackedTrack,
  getDataBackedTrackSlugs,
  type CourseLessonArticle,
  type DataBackedTrackSlug,
} from '../../../../data/lessonRegistry';
import { withBase } from '../../../../utils/paths';

interface Props {
  slug: DataBackedTrackSlug;
  course: Course;
  lesson: CourseLessonArticle;
  previousLesson: CourseLessonArticle | null;
  nextLesson: CourseLessonArticle | null;
  allLessons: CourseLessonArticle[];
}

export function getStaticPaths() {
  return getDataBackedTrackSlugs().flatMap((slug) => {
    const track = getDataBackedTrack(slug, 'en');

    if (!track) {
      throw new Error(`Data-backed track not found for slug: ${slug}`);
    }

    return track.lessons.map((lesson, index) => ({
      params: { slug, lesson: lesson.slug },
      props: {
        slug,
        course: track.course,
        lesson,
        previousLesson: index > 0 ? track.lessons[index - 1] : null,
        nextLesson: index < track.lessons.length - 1 ? track.lessons[index + 1] : null,
        allLessons: track.lessons,
      },
    }));
  });
}

const { slug, course, lesson, previousLesson, nextLesson, allLessons } = Astro.props as Props;
const estimatedMinutes = Math.max(4, Math.ceil((lesson.exampleCode.length + lesson.lessonNotes.join(' ').length) / 900));
const articleSections = [
  { id: 'learning-points', title: 'What you will learn' },
  { id: 'lesson-notes', title: 'Lesson notes' },
  { id: 'example', title: 'Example' },
  { id: 'practice', title: 'Practice' },
  { id: 'references', title: 'References' },
];
---

<BaseLayout
  title={`${lesson.title} · ${course.title}`}
  description={lesson.summary}
  currentCourse={course}
>
  <section class="page-intro page-intro--course page-intro--editorial" style={`--course-accent: ${course.accent}`}>
    <div class="page-intro-backdrop"></div>
    <div class="container page-intro-inner">
      <a href={withBase(`/courses/${slug}/lessons`)} class="back-link">← Back to {course.title} lessons</a>

      <div class="course-hero-grid course-hero-grid--editorial">
        <div>
          <p class="eyebrow">Lesson {lesson.lesson}</p>
          <h1 class="page-title">{lesson.title}</h1>
          <p class="lead narrow">{lesson.summary}</p>
        </div>

        <aside class="course-summary-card course-summary-card--editorial">
          <h2>Lesson summary</h2>
          <dl>
            <div>
              <dt>Track</dt>
              <dd>{course.title}</dd>
            </div>
            <div>
              <dt>Module</dt>
              <dd>{lesson.moduleTitle}</dd>
            </div>
            <div>
              <dt>Focus</dt>
              <dd>{lesson.learningPoints.join(', ')}</dd>
            </div>
            <div>
              <dt>Read time</dt>
              <dd>~{estimatedMinutes} min</dd>
            </div>
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <section class="floating-panel-wrap floating-panel-wrap--page">
    <div class="container">
      <div class="main-panel">
        <section class="panel-section panel-section--first">
          <div class="course-layout note-layout">
            <div class="course-main-column">
              <div class="content-panel content-panel--editorial note-panel note-article-overview">
                <div>
                  <p class="eyebrow">Article overview</p>
                  <h2>{lesson.intro}</h2>
                  <p>
                    Use this lesson page to review the core ideas, walk through the example, then reinforce your understanding with practice and references.
                  </p>
                </div>
                <div class="note-tag-list">
                  <span class="note-tag">{course.title}</span>
                  <span class="note-tag">{lesson.moduleTitle}</span>
                  <span class="note-tag">Lesson {lesson.lesson}</span>
                </div>
              </div>

              <div class="content-panel content-panel--editorial note-panel" id="learning-points">
                <div class="section-heading section-heading--editorial">
                  <h2>What you will learn</h2>
                  <p>Use the learning goals first to lock onto the ideas worth remembering most.</p>
                </div>
                <ul class="simple-list">
                  {lesson.learningPoints.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>

              <div class="content-panel content-panel--editorial note-panel" id="lesson-notes">
                <div class="section-heading section-heading--editorial">
                  <h2>Lesson notes</h2>
                  <p>The main teaching notes and concept summary for this lesson.</p>
                </div>
                <div class="article-flow">
                  {lesson.lessonNotes.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
              </div>

              <div class="content-panel content-panel--editorial note-panel" id="example">
                <div class="section-heading section-heading--editorial">
                  <h2>Example</h2>
                  <p>Start with a small understandable example that connects the concept to practical code.</p>
                </div>
                <pre class="note-code-block"><code>{lesson.exampleCode}</code></pre>
              </div>

              <div class="content-panel content-panel--editorial note-panel" id="practice">
                <div class="section-heading section-heading--editorial">
                  <h2>Practice</h2>
                  <p>Turn the lesson into action with practice. It sticks better than reading alone.</p>
                </div>
                <ul class="simple-list">
                  {lesson.practice.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>

              <div class="content-panel content-panel--editorial note-panel" id="references">
                <div class="section-heading section-heading--editorial">
                  <h2>References</h2>
                  <p>Use these links when you want to continue into official docs or further reading.</p>
                </div>
                <ul class="simple-list">
                  {lesson.references.map((item) => (
                    <li><a href={item.url} target="_blank" rel="noreferrer">{item.label}</a></li>
                  ))}
                </ul>
              </div>
            </div>

            <aside class="course-side-column note-side-column">
              <div class="content-panel content-panel--editorial sticky-panel note-panel">
                <div class="section-heading section-heading--editorial">
                  <h2>Reading guide</h2>
                  <p>Get the reading order first, then decide whether to skim or read the whole lesson carefully.</p>
                </div>

                <div class="lesson-anchor-list">
                  {articleSections.map((section) => (
                    <a class="lesson-anchor-link" href={`#${section.id}`}>
                      <span>Section</span>
                      <strong>{section.title}</strong>
                    </a>
                  ))}
                </div>

                <h3 class="note-side-heading">Why this matters</h3>
                <ul class="simple-list simple-list--compact">
                  {lesson.reasons.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>

                <h3 class="note-side-heading">Common mistakes</h3>
                <ul class="simple-list simple-list--compact">
                  {lesson.mistakes.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>

                <h3 class="note-side-heading">Key takeaway</h3>
                <ul class="simple-list simple-list--compact">
                  {lesson.takeaways.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>

              <div class="content-panel content-panel--editorial note-panel note-progress-panel">
                <div class="section-heading section-heading--editorial">
                  <h2>Course progress</h2>
                  <p>See where you are in the track and jump directly to other lessons.</p>
                </div>

                <p class="note-progress-copy">Current lesson: Lesson {lesson.lesson} / {allLessons.length}</p>
                <div class="lesson-progress-bar" aria-hidden="true">
                  <span style={`width: ${(lesson.lesson / allLessons.length) * 100}%`}></span>
                </div>

                <div class="lesson-mini-nav">
                  {allLessons.map((entry) => (
                    <a
                      href={withBase(`/courses/${slug}/lessons/${entry.slug}`)}
                      class:list={['lesson-mini-link', { 'is-active': entry.slug === lesson.slug }]}
                    >
                      <span>Lesson {entry.lesson}</span>
                      <strong>{entry.title}</strong>
                    </a>
                  ))}
                </div>
              </div>
            </aside>
          </div>
        </section>

        <section class="panel-section">
          <div class="section-heading section-heading--editorial">
            <h2>Lesson continuity</h2>
            <p>Keep the learning flow going by moving smoothly from one lesson to the next.</p>
          </div>

          <div class="notes-list notes-list--continuity">
            {previousLesson && (
              <a class="note-card" href={withBase(`/courses/${slug}/lessons/${previousLesson.slug}`)}>
                <div class="note-card-meta">
                  <span class="course-pill">Previous</span>
                </div>
                <h3>{previousLesson.title}</h3>
                <p>{previousLesson.summary}</p>
              </a>
            )}

            {nextLesson && (
              <a class="note-card" href={withBase(`/courses/${slug}/lessons/${nextLesson.slug}`)}>
                <div class="note-card-meta">
                  <span class="course-pill">Next</span>
                </div>
                <h3>{nextLesson.title}</h3>
                <p>{nextLesson.summary}</p>
              </a>
            )}
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
