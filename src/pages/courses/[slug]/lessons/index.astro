---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import type { Course } from '../../../../data/courses';
import {
  getDataBackedTrack,
  getDataBackedTrackSlugs,
  type CourseLessonArticle,
  type DataBackedTrackSlug,
} from '../../../../data/lessonRegistry';
import { withBase } from '../../../../utils/paths';

interface Props {
  slug: DataBackedTrackSlug;
  course: Course;
  lessons: CourseLessonArticle[];
}

export function getStaticPaths() {
  return getDataBackedTrackSlugs().map((slug) => {
    const track = getDataBackedTrack(slug, 'en');

    if (!track) {
      throw new Error(`Data-backed track not found for slug: ${slug}`);
    }

    return {
      params: { slug },
      props: {
        slug,
        course: track.course,
        lessons: track.lessons,
      },
    };
  });
}

const { slug, course, lessons } = Astro.props as Props;
const firstLesson = lessons[0];
const latestLesson = lessons[lessons.length - 1];
const totalModules = course.modules.length;
const currentLessonCount = lessons.length;
const lessonsByModule = new Map<string, CourseLessonArticle[]>();

for (const lesson of lessons) {
  const existingLessons = lessonsByModule.get(lesson.moduleTitle) ?? [];
  existingLessons.push(lesson);
  lessonsByModule.set(lesson.moduleTitle, existingLessons);
}

const noteModules = course.modules.map((module) => ({
  title: module.title,
  description: module.description,
  lessons: lessonsByModule.get(module.title) ?? [],
}));

const firstModule = course.modules[0];
const middleModule = course.modules[Math.min(2, course.modules.length - 1)] ?? firstModule;
const finalModule = course.modules[course.modules.length - 1] ?? middleModule;

const roadmapHighlights = [
  `Use the module map first to see how ${course.title} moves from foundations into practical implementation work.`,
  'Use this page as your study map first, then open each lesson article when you want to go deeper.',
  'If you want to follow the core path in order, start from Lesson 1 and continue straight through the track.',
];

const learningPromises = [
  `Build a clear mental model around ${course.focus.join(', ')} through one connected lesson path.`,
  'Move from concept notes into full article pages with examples, practice prompts, and references.',
  `Revisit the ${course.title} track as a structured library whenever you need a quick review or deeper study.`,
];
---

<BaseLayout
  title={`${course.title} lessons · ${course.title}`}
  description={`Browse the formal ${course.title} lesson library and article pages.`}
  currentCourse={course}
>
  <section class="page-intro page-intro--course page-intro--editorial" style={`--course-accent: ${course.accent}`}>
    <div class="page-intro-backdrop"></div>
    <div class="container page-intro-inner">
      <a href={withBase('/courses')} class="back-link">← Back to all tracks</a>
      <div class="course-hero-grid course-hero-grid--editorial">
        <div>
          <p class="eyebrow">Course home</p>
          <h1 class="page-title">{course.title} lessons</h1>
          <p class="lead narrow">
            This track turns the {course.title} learning path into a readable course home, from foundations into practical delivery, with every stop connected to a full lesson article.
          </p>

          <div class="hero-actions course-home-actions">
            {firstLesson ? (
              <a class="hero-action hero-action--primary" href={withBase(`/courses/${slug}/lessons/${firstLesson.slug}`)}>
                Start from Lesson 1
              </a>
            ) : null}
            {latestLesson ? (
              <a class="hero-action" href={withBase(`/courses/${slug}/lessons/${latestLesson.slug}`)}>
                Jump to the final lesson
              </a>
            ) : null}
          </div>
        </div>

        <aside class="course-summary-card course-summary-card--editorial course-summary-card--dense">
          <h2>Notes overview</h2>
          <dl>
            <div>
              <dt>Current lessons</dt>
              <dd>{currentLessonCount}</dd>
            </div>
            <div>
              <dt>Planned lessons</dt>
              <dd>{course.totalLessons}</dd>
            </div>
            <div>
              <dt>Total modules</dt>
              <dd>{totalModules}</dd>
            </div>
            <div>
              <dt>Course focus</dt>
              <dd>{course.focus.join(', ')}</dd>
            </div>
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <section class="floating-panel-wrap floating-panel-wrap--page">
    <div class="container">
      <div class="main-panel">
        <section class="panel-section panel-section--first">
          <div class="section-heading section-heading--editorial">
            <h2>Start here</h2>
            <p>Use this page to get the lesson sequence and big-picture flow before you dive into each article.</p>
          </div>

          <div class="course-home-grid">
            <article class="content-panel content-panel--editorial note-panel course-home-feature">
              <p class="eyebrow">Reading flow</p>
              <h3>Read the module path first, then move into the full lesson articles</h3>
              <p>
                If you want to move through this topic in a steady order, use this page to understand the structure first and then continue lesson by lesson through the full articles.
              </p>
              <ul class="simple-list simple-list--compact">
                {roadmapHighlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            </article>

            <aside class="content-panel content-panel--editorial note-panel course-home-aside">
              <p class="eyebrow">What you will get</p>
              <h3>This track connects the core skills into one path you can revisit and review</h3>
              <ul class="simple-list simple-list--compact">
                {learningPromises.map((promise) => (
                  <li>{promise}</li>
                ))}
              </ul>
            </aside>
          </div>
        </section>

        <section class="panel-section">
          <div class="section-heading section-heading--editorial">
            <h2>Recommended path</h2>
            <p>If you do not want to decide the order yourself, start with this suggested sequence.</p>
          </div>

          <div class="course-home-steps">
            <article class="course-step-card">
              <span class="course-step-number">01</span>
              <h3>Start with {firstModule?.title ?? 'foundations'}</h3>
              <p>Build confidence with the core concepts first so later implementation decisions feel steadier.</p>
            </article>
            <article class="course-step-card">
              <span class="course-step-number">02</span>
              <h3>Then move into {middleModule?.title ?? 'core implementation'}</h3>
              <p>Use the middle modules to connect concepts into practical coding patterns and reliable workflows.</p>
            </article>
            <article class="course-step-card">
              <span class="course-step-number">03</span>
              <h3>Finish with {finalModule?.title ?? 'delivery and review'}</h3>
              <p>Use the final module as your delivery and refinement stage so the full track feels complete.</p>
            </article>
          </div>
        </section>

        <section class="panel-section">
          <div class="section-heading section-heading--editorial">
            <h2>Module map</h2>
            <p>Use the module groups to understand the learning path first, then dive into each lesson.</p>
          </div>

          <div class="module-list">
            {noteModules.map((module) => (
              <article class="module-card module-card--editorial module-card--course-home">
                <div class="module-head module-head--course-home">
                  <div>
                    <p class="eyebrow">Module</p>
                    <h3>{module.title}</h3>
                  </div>
                  <p>{module.description}</p>
                </div>

                <div class="notes-list notes-list--module">
                  {module.lessons.map((lesson) => (
                    <a class="note-card note-card--course-home" href={withBase(`/courses/${slug}/lessons/${lesson.slug}`)}>
                      <div class="note-card-meta">
                        <span class="course-pill">Lesson {lesson.lesson}</span>
                        <span class="note-card-arrow" aria-hidden="true">↗</span>
                      </div>
                      <h3>{lesson.title}</h3>
                      <p>{lesson.summary}</p>
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="panel-section">
          <div class="section-heading section-heading--editorial">
            <h2>All lessons</h2>
            <p>Every lesson listed here already has a full article page behind it.</p>
          </div>

          <div class="notes-list notes-list--compact-cards">
            {lessons.map((lesson) => (
              <a class="note-card note-card--compact" href={withBase(`/courses/${slug}/lessons/${lesson.slug}`)}>
                <div class="note-card-meta">
                  <span class="course-pill">Lesson {lesson.lesson}</span>
                  <span class="note-card-arrow" aria-hidden="true">↗</span>
                </div>
                <h3>{lesson.title}</h3>
                <p>{lesson.summary}</p>
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
