---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CourseCard from '../../../components/CourseCard.astro';
import { getCourses } from '../../../data/courses';

const locale = 'zh' as const;
const courses = getCourses(locale);
---

<BaseLayout
  title="教學筆記 · Tommy's Notes"
  description="瀏覽涵蓋前端、後端、資料庫與系統主題的教學主題線。"
  locale={locale}
>
  <section class="page-intro page-intro--editorial">
    <div class="page-intro-backdrop"></div>
    <div class="container page-intro-inner">
      <p class="eyebrow">教學主題線</p>
      <h1 class="page-title">把學過的主題，整理成一套能反覆複習的教學內容。</h1>
      <p class="lead narrow">
        每個主題都獨立整理，避免知識混在一起，也讓後續新增課程內容時更容易延伸。
      </p>
    </div>
  </section>

  <section class="floating-panel-wrap floating-panel-wrap--page">
    <div class="container">
      <div class="main-panel">
        <section class="panel-section panel-section--first">
          <div class="course-grid course-grid--editorial">
            {courses.map((course) => (
              <CourseCard course={course} locale={locale} />
            ))}
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
